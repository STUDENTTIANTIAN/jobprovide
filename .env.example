# 数据库
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/subtitle

# Redis
REDIS_URL=redis://localhost:6379/0

# HuggingFace TEI (Text Embeddings Inference)
TEI_URL=http://localhost:8081

# Qdrant Vector Database
QDRANT_URL=http://localhost:6333

# 匹配权重
KEYWORD_WEIGHT=0.4
SEMANTIC_WEIGHT=0.6

# ============================================
# 语音识别配置（可选）
# ============================================
# 提供商选择: mimo / iflytek / baidu / tencent / generic
SPEECH_PROVIDER=mimo

# ============================================
# 方案1: 小米 MiMo 语音识别（推荐）
# 模型: mimo-v2.5-asr
# ============================================
MIMO_API_KEY=你的API密钥
MIMO_API_URL=https://api.mimo.xiaomi.com/v1/audio/transcriptions
MIMO_MODEL=mimo-v2.5-asr

# ============================================
# 方案2: 讯飞语音识别
# 文档: https://www.xfyun.cn/doc/asr/ifaas/API.html
# ============================================
# SPEECH_PROVIDER=iflytek
# IFLYTEK_APP_ID=你的APP_ID
# IFLYTEK_API_KEY=你的API_KEY
# IFLYTEK_API_SECRET=你的API_SECRET

# ============================================
# 方案3: 百度语音识别
# 文档: https://ai.baidu.com/ai-doc/SPEECH/Vk38lxily
# ============================================
# SPEECH_PROVIDER=baidu
# BAIDU_API_KEY=你的API_KEY
# BAIDU_API_SECRET=你的SECRET_KEY

# ============================================
# 方案4: 腾讯云语音识别
# 文档: https://cloud.tencent.com/document/product/1093/37138
# ============================================
# SPEECH_PROVIDER=tencent
# TENCENT_SECRET_ID=你的SecretId
# TENCENT_SECRET_KEY=你的SecretKey

# ============================================
# 方案5: 通用接口
# ============================================
# SPEECH_PROVIDER=generic
# SPEECH_API_KEY=你的API密钥
# SPEECH_API_URL=https://your-api.com/transcribe
