# 数据库
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/subtitle

# Redis
REDIS_URL=redis://localhost:6379/0

# HuggingFace TEI (Text Embeddings Inference)
TEI_URL=http://localhost:8081

# Qdrant Vector Database
QDRANT_URL=http://localhost:6333

# 匹配权重
KEYWORD_WEIGHT=0.4
SEMANTIC_WEIGHT=0.6

# ============================================
# 语音识别配置（可选）
# ============================================
# 提供商选择: iflytek / baidu / tencent / generic
SPEECH_PROVIDER=generic

# ============================================
# 方案1: 讯飞语音识别（推荐）
# 文档: https://www.xfyun.cn/doc/asr/ifaas/API.html
# ============================================
IFLYTEK_APP_ID=your-app-id
IFLYTEK_API_KEY=your-api-key
IFLYTEK_API_SECRET=your-api-secret

# ============================================
# 方案2: 百度语音识别
# 文档: https://ai.baidu.com/ai-doc/SPEECH/Vk38lxily
# ============================================
BAIDU_API_KEY=your-api-key
BAIDU_API_SECRET=your-api-secret

# ============================================
# 方案3: 腾讯云语音识别
# 文档: https://cloud.tencent.com/document/product/1093/37138
# 需要安装SDK: pip install tencentcloud-sdk-python
# ============================================
TENCENT_SECRET_ID=your-secret-id
TENCENT_SECRET_KEY=your-secret-key

# ============================================
# 方案4: 通用接口
# 自定义API地址和密钥
# ============================================
SPEECH_API_KEY=your-api-key
SPEECH_API_URL=https://your-api-url.com/transcribe
